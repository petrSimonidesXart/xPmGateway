{
    "name": "xpm/gateway-adapter",
    "description": "PM Gateway Adapter - MCP Gateway + Admin UI",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "nette/application": "^3.2",
        "nette/bootstrap": "^3.2",
        "nette/di": "^3.2",
        "nette/http": "^3.2",
        "nette/security": "^3.2",
        "nette/forms": "^3.2",
        "nette/database": "^3.2",
        "nette/caching": "^3.2",
        "nette/utils": "^4.0",
        "nette/schema": "^1.3",
        "nette/mail": "^4.0",
        "latte/latte": "^3.0",
        "tracy/tracy": "^2.10",
        "nextras/migrations": "^3.3",
        "contributte/console": "^0.9",
        "opis/json-schema": "^2.3"
    },
    "require-dev": {
        "nette/tester": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "allow-plugins": {
            "nette/component-model": true
        }
    }
}
