services:
    router: App\Router\RouterFactory::createRouter

    # Services
    - App\Model\Service\AuthService
    - App\Model\Service\JobService
    - App\Model\Service\AuditService
    - App\Model\Service\SchemaValidator

    encryptionService:
        factory: App\Model\Service\EncryptionService(%security.encryptionKey%)

    rateLimitService:
        factory: App\Model\Service\RateLimitService
        arguments:
            rateLimitPerMinute: int(%security.rateLimitPerMinute%)

    alertService:
        factory: App\Model\Service\AlertService
        arguments:
            alertEmail: %alerting.email%

    artifactService:
        factory: App\Model\Service\ArtifactService
        arguments:
            storageDir: %appDir%/../storage

    # Mailer - override built-in mail.mailer
    mail.mailer:
        factory: Nette\Mail\SmtpMailer(%smtp.host%, %smtp.user%, %smtp.password%, int(%smtp.port%))

    # Repositories
    - App\Model\Repository\ClientRepository
    - App\Model\Repository\ApiTokenRepository
    - App\Model\Repository\ServiceAccountRepository
    - App\Model\Repository\ToolRepository
    - App\Model\Repository\ClientPermissionRepository
    - App\Model\Repository\JobRepository
    - App\Model\Repository\AuditLogRepository
    - App\Model\Repository\RateLimitRepository
    - App\Model\Repository\AdminUserRepository
    - App\Model\Repository\ArtifactRepository

    # Facades
    - App\Model\Facade\McpFacade
    - App\Model\Facade\JobFacade

    # Internal API - inject secret
    -
        factory: App\Module\Internal\Presenters\JobsPresenter
        arguments:
            internalApiSecret: %security.internalApiSecret%
