<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ifset title}{include title} | {/ifset}PM Gateway Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
    <style>
        .badge-pending { background: var(--tblr-yellow); color: var(--tblr-yellow-fg); }
        .badge-processing { background: var(--tblr-azure); color: #fff; }
        .badge-success { background: var(--tblr-green); color: #fff; }
        .badge-failed { background: var(--tblr-red); color: #fff; }
        .badge-timeout { background: var(--tblr-secondary); color: #fff; }

        .worker-status-bar {
            padding: 5px 0;
            font-size: 0.8125rem;
            color: #fff;
            transition: background-color 0.3s;
            cursor: default;
        }
        .ws-idle { background: #2fb344; }
        .ws-busy { background: #206bc4; }
        .ws-offline { background: #d63939; }
        .ws-unknown { background: #667382; }
        .ws-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #fff;
        }
        .ws-busy .ws-dot {
            animation: ws-pulse 1.5s ease-in-out infinite;
        }
        @keyframes ws-pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
        #ws-details {
            display: none;
            padding-bottom: 4px;
        }
        #ws-details a { color: #fff; }
    </style>
</head>
<body class="page">
    <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu"
                    aria-controls="sidebar-menu" aria-expanded="false" aria-label="Navigace">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a href="{plink :Admin:Dashboard:default}" class="navbar-brand navbar-brand-autodark">
                <span class="fs-3 fw-bold">PM Gateway</span>
            </a>
            <div class="collapse navbar-collapse" id="sidebar-menu">
                <ul class="navbar-nav pt-lg-3">
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Dashboard:*') ? active" href="{plink :Admin:Dashboard:default}">
                            <span class="nav-link-icon"><i class="ti ti-dashboard"></i></span>
                            <span class="nav-link-title">Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Client:*') || $presenter->isLinkCurrent(':Admin:Token:*') ? active" href="{plink :Admin:Client:default}">
                            <span class="nav-link-icon"><i class="ti ti-users"></i></span>
                            <span class="nav-link-title">Klienti</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:ServiceAccount:*') ? active" href="{plink :Admin:ServiceAccount:default}">
                            <span class="nav-link-icon"><i class="ti ti-key"></i></span>
                            <span class="nav-link-title">Service Accounts</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Tool:*') ? active" href="{plink :Admin:Tool:default}">
                            <span class="nav-link-icon"><i class="ti ti-tool"></i></span>
                            <span class="nav-link-title">Tooly</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Job:*') ? active" href="{plink :Admin:Job:default}">
                            <span class="nav-link-icon"><i class="ti ti-list-check"></i></span>
                            <span class="nav-link-title">Joby</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:AuditLog:*') ? active" href="{plink :Admin:AuditLog:default}">
                            <span class="nav-link-icon"><i class="ti ti-file-text"></i></span>
                            <span class="nav-link-title">Audit Log</span>
                        </a>
                    </li>
                    {if $isAdmin}
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:User:*') ? active" href="{plink :Admin:User:default}">
                            <span class="nav-link-icon"><i class="ti ti-user-cog"></i></span>
                            <span class="nav-link-title">Uživatelé</span>
                        </a>
                    </li>
                    {/if}
                </ul>
                <div class="mt-auto p-3 d-flex align-items-center">
                    <span class="avatar avatar-sm bg-blue-lt">
                        <i class="ti ti-user"></i>
                    </span>
                    <div class="ms-2 lh-sm">
                        <div class="small fw-bold text-white">{$currentUser->username}</div>
                        <div class="text-white-50 small">{$currentUser->getRoles()[0] ?? 'user'}</div>
                    </div>
                    <a href="{plink :Admin:Sign:out}" class="ms-auto text-white" title="Odhlásit">
                        <i class="ti ti-logout"></i>
                    </a>
                </div>
            </div>
        </div>
    </aside>
    <div class="page-wrapper">
        <div class="worker-status-bar ws-unknown" id="worker-status-bar"
             data-url="{plink :Admin:Dashboard:workerStatus}"
             data-job-url="{plink :Admin:Job:detail '__ID__'}">
            <div class="container-xl d-flex align-items-center">
                <span class="ws-dot"></span>
                <span class="ms-2" id="ws-text">Worker: …</span>
                <span class="ms-2 opacity-75 d-none" id="ws-detail"></span>
                <button class="btn btn-link btn-sm ms-auto p-0 text-white opacity-75" id="ws-toggle" title="Detail">
                    <i class="ti ti-chevron-down" id="ws-toggle-icon"></i>
                </button>
            </div>
            <div id="ws-details">
                <div class="container-xl" id="ws-details-content"></div>
            </div>
        </div>
        <div class="page-header d-print-none">
            <div class="container-xl">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <h2 class="page-title">{ifset title}{include title}{/ifset}</h2>
                    </div>
                    {ifset actions}
                    <div class="col-auto ms-auto">
                        {include actions}
                    </div>
                    {/ifset}
                </div>
            </div>
        </div>
        <div class="page-body">
            <div class="container-xl">
                {foreach $flashes as $flash}
                    <div n:class="alert, $flash->type === 'warning' ? alert-warning : alert-success, alert-dismissible" role="alert">
                        <div class="d-flex">
                            <div><i n:class="ti, me-2, $flash->type === 'warning' ? ti-alert-triangle : ti-check"></i></div>
                            <div>{$flash->message}</div>
                        </div>
                        <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
                    </div>
                {/foreach}
                {include content}
            </div>
        </div>
    </div>
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"
         data-notifications-url="{plink :Admin:Job:notifications}"
         data-job-detail-url="{plink :Admin:Job:detail '__ID__'}"></div>
    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
    <script n:syntax="off">
    (function() {
        const POLL_INTERVAL = 15000;
        const container = document.getElementById('toast-container');
        const NOTIFICATIONS_URL = container.dataset.notificationsUrl;
        const JOB_DETAIL_URL = container.dataset.jobDetailUrl;
        const shownIds = new Set(JSON.parse(localStorage.getItem('pmg_shown') || '[]'));
        let since = localStorage.getItem('pmg_since') || new Date().toISOString();

        function showToast(job) {
            const isSuccess = job.status === 'success';
            const icon = isSuccess ? 'ti-circle-check' : 'ti-alert-circle';
            const color = isSuccess ? 'bg-green' : 'bg-red';
            const label = isSuccess ? 'Dokončen' : 'Selhal';
            const detail = job.error ? `: ${job.error.substring(0, 80)}` : '';

            const el = document.createElement('div');
            el.className = 'toast show';
            el.setAttribute('role', 'alert');
            el.innerHTML = `
                <div class="toast-header">
                    <span class="avatar avatar-xs ${color} me-2"><i class="ti ${icon} text-white"></i></span>
                    <strong class="me-auto">${label}</strong>
                    <small class="text-secondary">${job.client_name}</small>
                    <button type="button" class="ms-2 btn-close" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    <a href="${JOB_DETAIL_URL.replace('__ID__', job.id)}" class="text-reset">
                        <strong>${job.tool_name}</strong>${detail}
                    </a>
                </div>`;
            document.getElementById('toast-container').appendChild(el);
            const toast = new bootstrap.Toast(el, {autohide: true, delay: 8000});
            toast.show();
            el.addEventListener('hidden.bs.toast', () => el.remove());
        }

        async function poll() {
            try {
                const res = await fetch(`${NOTIFICATIONS_URL}?since=${encodeURIComponent(since)}`);
                if (!res.ok) return;
                const jobs = await res.json();
                for (const job of jobs) {
                    if (!shownIds.has(job.id)) {
                        shownIds.add(job.id);
                        showToast(job);
                    }
                }
                if (jobs.length > 0) {
                    since = jobs[0].finished_at;
                    localStorage.setItem('pmg_since', since);
                    // Keep shownIds bounded
                    const arr = [...shownIds];
                    if (arr.length > 200) {
                        const trimmed = arr.slice(-100);
                        shownIds.clear();
                        trimmed.forEach(id => shownIds.add(id));
                    }
                    localStorage.setItem('pmg_shown', JSON.stringify([...shownIds]));
                }
            } catch (e) { /* ignore network errors */ }
        }

        setInterval(poll, POLL_INTERVAL);
        setTimeout(poll, 2000);
    })();

    // Worker status bar
    (function() {
        var bar = document.getElementById('worker-status-bar');
        var STATUS_URL = bar.dataset.url;
        var JOB_URL = bar.dataset.jobUrl;
        var textEl = document.getElementById('ws-text');
        var detailEl = document.getElementById('ws-detail');
        var details = document.getElementById('ws-details');
        var detailsContent = document.getElementById('ws-details-content');
        var toggleBtn = document.getElementById('ws-toggle');
        var toggleIcon = document.getElementById('ws-toggle-icon');
        var expanded = false;

        toggleBtn.addEventListener('click', function() {
            expanded = !expanded;
            details.style.display = expanded ? 'block' : 'none';
            toggleIcon.className = expanded ? 'ti ti-chevron-up' : 'ti ti-chevron-down';
        });

        function dur(s) {
            if (s == null) return '—';
            if (s < 60) return s + 's';
            if (s < 3600) return Math.floor(s / 60) + 'm ' + (s % 60) + 's';
            return Math.floor(s / 3600) + 'h ' + Math.floor((s % 3600) / 60) + 'm';
        }

        function ts(iso) {
            if (!iso) return '—';
            return new Date(iso).toLocaleString('cs-CZ');
        }

        function render(d) {
            bar.className = 'worker-status-bar ws-' + d.status;

            if (d.status === 'idle') {
                textEl.textContent = 'Worker: Idle';
                detailEl.textContent = d.uptime_seconds ? 'Uptime: ' + dur(d.uptime_seconds) : '';
                detailEl.classList.toggle('d-none', !d.uptime_seconds);
            } else if (d.status === 'busy') {
                textEl.textContent = 'Worker zpracovává: ' + (d.job ? d.job.tool_name : '?');
                detailEl.textContent = d.job ? d.job.client_name + ' · ' + dur(d.job.duration_seconds) : '';
                detailEl.classList.remove('d-none');
            } else if (d.status === 'offline') {
                textEl.textContent = 'Worker: Offline';
                detailEl.textContent = d.last_seen_at ? 'Naposledy: ' + ts(d.last_seen_at) : '';
                detailEl.classList.toggle('d-none', !d.last_seen_at);
            } else {
                textEl.textContent = 'Worker: Nepřipojen';
                detailEl.textContent = 'Worker se dosud nepřipojil k adapteru';
                detailEl.classList.remove('d-none');
            }

            var html = '';
            if (d.started_at) html += '<div>Spuštěn od: ' + ts(d.started_at) + '</div>';
            if (d.last_seen_at) html += '<div>Naposledy viděn: ' + ts(d.last_seen_at) + '</div>';
            if (d.uptime_seconds) html += '<div>Uptime: ' + dur(d.uptime_seconds) + '</div>';
            if (d.job) {
                html += '<div class="mt-1 pt-1" style="border-top: 1px solid rgba(255,255,255,0.25);">';
                html += '<div>Job: <a href="' + JOB_URL.replace('__ID__', d.job.id) + '">' + d.job.id.substring(0, 8) + '…</a></div>';
                html += '<div>Tool: ' + d.job.tool_name + '</div>';
                html += '<div>Klient: ' + d.job.client_name + '</div>';
                html += '<div>Trvání: ' + dur(d.job.duration_seconds) + '</div>';
                html += '</div>';
            }
            detailsContent.innerHTML = html;
        }

        async function pollStatus() {
            try {
                var res = await fetch(STATUS_URL);
                if (res.ok) render(await res.json());
            } catch (e) { /* ignore */ }
        }

        setInterval(pollStatus, 10000);
        pollStatus();
    })();
    </script>
</body>
</html>
