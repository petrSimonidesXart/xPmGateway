<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ifset title}{include title} | {/ifset}PM Gateway Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .sidebar { min-height: 100vh; }
        .badge-pending { background-color: #ffc107; color: #000; }
        .badge-processing { background-color: #17a2b8; }
        .badge-success { background-color: #28a745; }
        .badge-failed { background-color: #dc3545; }
        .badge-timeout { background-color: #6c757d; }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar bg-dark text-white p-3" style="width: 220px;">
            <h5 class="mb-4">PM Gateway</h5>
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:Dashboard:default}">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:Client:default}">Klienti</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:ServiceAccount:default}">Service Accounts</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:Tool:default}">Tooly</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:Job:default}">Joby</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:AuditLog:default}">Audit Log</a></li>
                {if $isAdmin}
                <li class="nav-item"><a class="nav-link text-white" href="{plink :Admin:User:default}">Uživatelé</a></li>
                {/if}
            </ul>
            <hr class="text-white">
            <div class="small text-muted">
                {$currentUser->username} ({$currentUser->getRoles()[0] ?? 'user'})
            </div>
            <a class="nav-link text-white small" href="{plink :Admin:Sign:out}">Odhlásit</a>
        </nav>
        <main class="flex-grow-1 p-4">
            {foreach $flashes as $flash}
                <div class="alert alert-{$flash->type === 'warning' ? 'warning' : 'success'} alert-dismissible fade show">
                    {$flash->message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {/foreach}
            {include content}
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
