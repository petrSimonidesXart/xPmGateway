<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ifset title}{include title} | {/ifset}PM Gateway Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
    <style>
        .badge-pending { background: var(--tblr-yellow); color: var(--tblr-yellow-fg); }
        .badge-processing { background: var(--tblr-azure); color: #fff; }
        .badge-success { background: var(--tblr-green); color: #fff; }
        .badge-failed { background: var(--tblr-red); color: #fff; }
        .badge-timeout { background: var(--tblr-secondary); color: #fff; }
    </style>
</head>
<body class="page">
    <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu"
                    aria-controls="sidebar-menu" aria-expanded="false" aria-label="Navigace">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a href="{plink :Admin:Dashboard:default}" class="navbar-brand navbar-brand-autodark">
                <span class="fs-3 fw-bold">PM Gateway</span>
            </a>
            <div class="collapse navbar-collapse" id="sidebar-menu">
                <ul class="navbar-nav pt-lg-3">
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Dashboard:*') ? active" href="{plink :Admin:Dashboard:default}">
                            <span class="nav-link-icon"><i class="ti ti-dashboard"></i></span>
                            <span class="nav-link-title">Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Client:*') || $presenter->isLinkCurrent(':Admin:Token:*') ? active" href="{plink :Admin:Client:default}">
                            <span class="nav-link-icon"><i class="ti ti-users"></i></span>
                            <span class="nav-link-title">Klienti</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:ServiceAccount:*') ? active" href="{plink :Admin:ServiceAccount:default}">
                            <span class="nav-link-icon"><i class="ti ti-key"></i></span>
                            <span class="nav-link-title">Service Accounts</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Tool:*') ? active" href="{plink :Admin:Tool:default}">
                            <span class="nav-link-icon"><i class="ti ti-tool"></i></span>
                            <span class="nav-link-title">Tooly</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:Job:*') ? active" href="{plink :Admin:Job:default}">
                            <span class="nav-link-icon"><i class="ti ti-list-check"></i></span>
                            <span class="nav-link-title">Joby</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:AuditLog:*') ? active" href="{plink :Admin:AuditLog:default}">
                            <span class="nav-link-icon"><i class="ti ti-file-text"></i></span>
                            <span class="nav-link-title">Audit Log</span>
                        </a>
                    </li>
                    {if $isAdmin}
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent(':Admin:User:*') ? active" href="{plink :Admin:User:default}">
                            <span class="nav-link-icon"><i class="ti ti-user-cog"></i></span>
                            <span class="nav-link-title">Uživatelé</span>
                        </a>
                    </li>
                    {/if}
                </ul>
                <div class="mt-auto p-3 d-flex align-items-center">
                    <span class="avatar avatar-sm bg-blue-lt">
                        <i class="ti ti-user"></i>
                    </span>
                    <div class="ms-2 lh-sm">
                        <div class="small fw-bold text-white">{$currentUser->username}</div>
                        <div class="text-white-50 small">{$currentUser->getRoles()[0] ?? 'user'}</div>
                    </div>
                    <a href="{plink :Admin:Sign:out}" class="ms-auto text-white" title="Odhlásit">
                        <i class="ti ti-logout"></i>
                    </a>
                </div>
            </div>
        </div>
    </aside>
    <div class="page-wrapper">
        <div class="page-header d-print-none">
            <div class="container-xl">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <h2 class="page-title">{ifset title}{include title}{/ifset}</h2>
                    </div>
                    {ifset actions}
                    <div class="col-auto ms-auto">
                        {include actions}
                    </div>
                    {/ifset}
                </div>
            </div>
        </div>
        <div class="page-body">
            <div class="container-xl">
                {foreach $flashes as $flash}
                    <div n:class="alert, $flash->type === 'warning' ? alert-warning : alert-success, alert-dismissible" role="alert">
                        <div class="d-flex">
                            <div><i n:class="ti, me-2, $flash->type === 'warning' ? ti-alert-triangle : ti-check"></i></div>
                            <div>{$flash->message}</div>
                        </div>
                        <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
                    </div>
                {/foreach}
                {include content}
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
</body>
</html>
