{block title}Chyba {$code}{/block}

{block content}
<div class="empty">
    <div class="empty-header">{$code}</div>
    <p class="empty-title">Chyba {$code}</p>
    <p class="empty-subtitle text-secondary">{$message}</p>
    <div class="empty-action">
        <a href="{plink :Admin:Dashboard:default}" class="btn btn-primary">
            <i class="ti ti-arrow-left me-1"></i>Zpět na dashboard
        </a>
    </div>
</div>
{/block}
