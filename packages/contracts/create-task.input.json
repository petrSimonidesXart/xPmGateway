{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
        },
        "project": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
        },
        "assignee": {
            "type": "string",
            "maxLength": 200
        },
        "due_date": {
            "type": "string",
            "format": "date",
            "description": "ISO 8601 date (YYYY-MM-DD)"
        },
        "estimate_hours": {
            "type": "number",
            "minimum": 0,
            "maximum": 10000
        }
    },
    "required": ["title", "project"],
    "additionalProperties": false
}
