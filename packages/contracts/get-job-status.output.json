{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "status": {
            "type": "string",
            "enum": ["pending", "processing", "success", "failed", "timeout"]
        },
        "result": {
            "type": "object"
        },
        "error": {
            "type": "string"
        },
        "finished_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": ["status"],
    "additionalProperties": false
}
