                "project": { "type": "string" },
                "due_date": { "type": "string" },
                "priority": { "type": "string" },
                "created": { "type": "string" },
                "description": { "type": "string" },
                "url": { "type": "string" },
                "error": { "type": "string" }
            }
        }
