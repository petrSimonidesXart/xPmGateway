{
    "type": "object",
    "properties": {
        "mode": {
            "type": "string",
            "enum": ["done", "queued"]
        },
        "job_id": {
            "type": "string",
            "format": "uuid"
        },
        "status": {
            "type": "string",
            "enum": ["pending", "processing", "success", "failed"]
        },
        "result": {
            "type": "object",
            "properties": {
                "message": { "type": "string" }
            }
        }
    },
    "required": ["mode", "status"]
}
