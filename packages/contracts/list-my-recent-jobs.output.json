{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "jobs": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "job_id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "tool_name": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string",
                        "enum": ["pending", "processing", "success", "failed", "timeout"]
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "finished_at": {
                        "type": ["string", "null"],
                        "format": "date-time"
                    }
                },
                "required": ["job_id", "tool_name", "status", "created_at"]
            }
        }
    },
    "required": ["jobs"],
    "additionalProperties": false
}
